# ============================================================================
# mleval — single source of truth for run/deploy configuration.
#
# 1. Copy this file to `.env` (gitignored).
# 2. Replace every REPLACE_ME with a real value.
# 3. Source it in your shell or rely on the Makefile's auto-include:
#       set -a && source .env && set +a   # bash
#       direnv allow                       # if you use direnv
#
# Anything in here is consumed by:
#   - the Makefile                       (kubectl helpers)
#   - deploy/k8s/*.yaml                  (envsubst-rendered at apply time)
#   - infra/agents/<name>/Dockerfile     (per-agent build-args)
# ============================================================================

# ----------------------------------------------------------------------------
# LLM provider  (these become a Kubernetes Secret via `make k8s-secret`)
# ----------------------------------------------------------------------------

# OpenRouter API key used by the agent. Required for any real run.
OPENROUTER_API_KEY=REPLACE_ME

# Optional. Only needed if the agent pulls gated HuggingFace models.
HF_TOKEN=

# OpenRouter model slug. Examples:
#   deepseek/deepseek-v4-flash       (paid, cheap — current pilot default)
#   deepseek/deepseek-v4-flash:free  (free tier — heavily rate-limited, smoke only)
#   deepseek/deepseek-v4-pro         (cost-optimal paid for full A/B)
#   anthropic/claude-opus-4-7        (highest capability, ~10x more expensive)
#   google/gemini-3-pro-preview      (frontier; high cost)
MLEVAL_LLM_MODEL=deepseek/deepseek-v4-flash

# ----------------------------------------------------------------------------
# Kubernetes target
# ----------------------------------------------------------------------------

# Nautilus namespace your account can deploy into. For our group, this is
# `ecepxie` (UCSD ECE PXIE lab allocation — has GPU quota + storage). Set
# whatever namespace your kubectl context has access to.
K8S_NAMESPACE=REPLACE_ME

# GPU resource name on Nautilus. The reference helper pod uses rtxa6000.
# Other valid options on Nautilus (verify with `kubectl get nodes -o yaml | grep nvidia.com`):
#   nvidia.com/rtxa6000   — RTX A6000 (48GB)        — `large-gpu` pool
#   nvidia.com/a100       — A100 (40/80GB)          — limited, high contention
#   nvidia.com/gpu        — any GPU (let scheduler pick)
GPU_TYPE=nvidia.com/rtxa6000

# ----------------------------------------------------------------------------
# Container image
# ----------------------------------------------------------------------------

IMAGE_REGISTRY=ghcr.io/kkuntal990
IMAGE_NAME=mleval-agent
IMAGE_TAG=dev

# ----------------------------------------------------------------------------
# AIDE pinning  (consumed by infra/agents/aide/Dockerfile via --build-arg)
# ----------------------------------------------------------------------------

AIDE_REPO=https://github.com/WecoAI/aideml.git
# Pin to a specific commit SHA before any real A/B run. `main` is OK for
# scaffold / smoke tests only.
AIDE_REF=main

# ----------------------------------------------------------------------------
# GHCR pull secret
# ----------------------------------------------------------------------------

# GitHub PAT with **read:packages** scope only (classic PAT, not fine-grained).
# Used by `make k8s-ghcr-pull-secret` to provision a Docker registry Secret in
# the namespace so Nautilus nodes can pull the private ghcr.io image. Keep
# separate from any write:packages PAT (which only lives on the build host).
GHCR_READ_TOKEN=REPLACE_ME

# ----------------------------------------------------------------------------
# Run defaults  (override per-run with `make TARGET VAR=...`)
# ----------------------------------------------------------------------------

# Identifier for the current A/B sweep. Bump per sweep so PVC paths stay
# disjoint (results land under /results/$MLEVAL_RUN_ID/<trajectory_id>/).
MLEVAL_RUN_ID=mvp-001

# Default seed for one-off MVP runs. The full A/B will use seed=0,1,2 across
# trajectories; this is just the default for ad-hoc smoke tests.
DEFAULT_SEED=0
