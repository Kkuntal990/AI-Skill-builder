# MLEvolve trajectory Job template. Rendered by `envsubst` per (task × cell × seed).
# DO NOT `kubectl apply -f` directly — apply via the orchestrator which
# substitutes env vars from .env + flags.
#
# Required env at render time:
#   IMAGE_REGISTRY IMAGE_NAME IMAGE_TAG GPU_TYPE
#   MLEVAL_RUN_ID MLEVAL_TRAJECTORY_ID MLEVAL_LLM_MODEL
#   TASK CELL SEED TIME_LIMIT_SECONDS STEP_LIMIT
#   ACTIVE_DEADLINE_SECONDS                 (== TIME_LIMIT_SECONDS + slack)
#   MLEVAL_SKILL_PATH                       (empty for without_skill cell)
#
# Differences vs the deleted AIDE template:
#   - image: ghcr.io/.../mleval-agent-mlevolve:dev (separate image)
#   - memory: 64Gi (MLEvolve's subprocess model should hold here; if not,
#     spike C1 fails and we know within one trajectory)
#   - no AIDE-specific env (OPENAI_BASE_URL is still set — same OpenRouter
#     wrapper as before — but no GENERATE_REPORT, no MLEVAL_*_REQS_PATH)

apiVersion: batch/v1
kind: Job
metadata:
  name: ${MLEVAL_TRAJECTORY_ID}
  labels:
    app: mleval
    agent: mlevolve
    run_id: "${MLEVAL_RUN_ID}"
    task: "${TASK}"
    cell: "${CELL}"
    seed: "${SEED}"
spec:
  # >0 so a NODE-level failure (eviction / NotReady / preemption on unreserved
  # capacity) reschedules instead of permanently failing the trajectory.
  # spike-018 lost 3 jobs at once when gpu00 went NotReady with backoffLimit:0.
  # A retry is a clean reseeded redo (MLEvolve doesn't persist the search tree),
  # so the seed keeps it deterministic.
  backoffLimit: 2
  # activeDeadlineSeconds is set at the POD level (template.spec) below, NOT
  # here. A JOB-level deadline counts from job creation and is NOT reset on
  # retry — so a late eviction's fresh retry gets deadline-killed before it can
  # finish (spike-018 with_skill-s0: retry started, DeadlineExceeded ~11 min
  # later, grader never ran). Per-pod deadline gives each attempt its full
  # budget; backoffLimit caps the number of attempts.
  ttlSecondsAfterFinished: 86400
  template:
    metadata:
      labels:
        app: mleval
        agent: mlevolve
        run_id: "${MLEVAL_RUN_ID}"
        task: "${TASK}"
        cell: "${CELL}"
        seed: "${SEED}"
    spec:
      restartPolicy: Never
      # Per-ATTEMPT wall cap — resets on each backoffLimit retry (unlike a
      # job-level deadline), so an evicted-then-rescheduled pod gets its full
      # time budget. Also the hard backstop if the watchdog/grader hangs.
      activeDeadlineSeconds: ${ACTIVE_DEADLINE_SECONDS}
      # 90s grace gives the entrypoint SIGTERM-trap room to write the
      # manifest + run adapter_mlevolve.
      terminationGracePeriodSeconds: 90
      imagePullSecrets:
        - name: ghcr-pull
      containers:
        - name: agent
          image: ${IMAGE_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
          imagePullPolicy: Always
          # Sized after spike-008/010 observation: actual pod-level peak
          # during real QLoRA training of Qwen2.5-3B on SAMSum is ~2 GiB
          # (training subprocess RSS ~2.1 GB + agent overhead ~0.6 GB).
          # GPU mem peaks at ~13.6 GiB (within A6000's 48 GiB easily).
          # Sized to 16 GiB. The earlier 8 GiB right-size (based on a ~2.7 GB
          # observed peak for *compact* trajectories) was too aggressive:
          # spike-012 without-skill-s2 was OOMKilled (exit 137) at 8 GiB. The
          # control cell tends to write memory-heavier code (e.g. dataset
          # augmentation / eager tokenization of all 14.7k SAMSum examples +
          # 3B-model eval generation), so an 8 GiB cap asymmetrically kills it
          # and confounds the A/B. 16 GiB covers that heavy-code case while
          # staying well under the GPU node's RAM.
          # Briefly raised to 32Gi (2026-06-12) to protect the ~6.2GB Qwen2.5-3B
          # page cache; reverted to 16Gi (2026-06-13) after measuring the real
          # cgroup peak in spike-024 (cgroup.v2 memory.peak): with_skill (GPU
          # train) = 8.75 GB incl. the model page cache, without_skill (CPU node)
          # = 5.33 GB. 16Gi (17.2 GB) is ~2x the observed peak AND still leaves
          # ~7GB above the 8.75GB working set, so the model page cache survives
          # across nodes — 32Gi was idle headroom. Note: the mem_sampler's
          # pgrp_rss column undercounts (it misses the node SUBPROCESS that does
          # the training); trust cgroup memory.peak, not that CSV, for sizing.
          # 2026-06-26: bumped 16Gi -> 32Gi. mvp-029 gsm8k with_skill ran at
          # cgroup.current=13.0/16 GiB (81%) and its first pod died abruptly
          # mid-LoRA-node (no traceback/finalize = OOMKill signature) -> Job
          # restart-from-scratch. gsm8k with_skill is HEAVIER than the spike-024
          # sizing assumed (and heavier than this run's without_skill peak,
          # 11.9 GiB), so 16Gi left no transient-spike margin. 32Gi restores it.
          resources:
            requests:
              ${GPU_TYPE}: "1"
              cpu: "2"
              memory: "32Gi"
            limits:
              ${GPU_TYPE}: "1"
              cpu: "2"
              memory: "32Gi"
          env:
            - name: KUBE_NODE_NAME
              valueFrom:
                fieldRef:
                  fieldPath: spec.nodeName
            - name: MLEVAL_RUN_ID
              value: "${MLEVAL_RUN_ID}"
            - name: MLEVAL_TRAJECTORY_ID
              value: "${MLEVAL_TRAJECTORY_ID}"
            - name: TASK
              value: "${TASK}"
            - name: CELL
              value: "${CELL}"
            - name: SEED
              value: "${SEED}"
            - name: TIME_LIMIT_SECONDS
              value: "${TIME_LIMIT_SECONDS}"
            - name: STEP_LIMIT
              value: "${STEP_LIMIT}"
            - name: MLEVAL_LLM_MODEL
              value: "${MLEVAL_LLM_MODEL}"
            - name: MLEVAL_OUTPUT_DIR
              value: "/results/${MLEVAL_RUN_ID}/${MLEVAL_TRAJECTORY_ID}"
            - name: MLEVAL_TASK_INSTRUCTION_PATH
              value: "/results/data/${TASK}/instruction.md"
            - name: MLEVAL_TASK_DATA_DIR
              value: "/results/data/${TASK}/data"
            - name: MLEVAL_SKILL_PATH
              value: "${MLEVAL_SKILL_PATH}"
            - name: MLEVAL_SKILL_LIBRARY
              value: "${MLEVAL_SKILL_LIBRARY}"
            - name: MLEVAL_LLM_TIMEOUT_SEC
              value: "${MLEVAL_LLM_TIMEOUT_SEC}"
            # Empty string lets entrypoint.sh default to TIME_LIMIT_SECONDS / 2.
            - name: MLEVAL_EXEC_TIMEOUT_SEC
              value: "${MLEVAL_EXEC_TIMEOUT_SEC}"
            - name: MLEVAL_PROMPTS_LOG
              value: "/results/${MLEVAL_RUN_ID}/${MLEVAL_TRAJECTORY_ID}/prompts.jsonl"

            - name: OPENAI_BASE_URL
              value: "https://openrouter.ai/api/v1"
            - name: MLEVAL_LLM_API_KEY
              valueFrom:
                secretKeyRef:
                  name: mleval-secrets
                  key: openrouter-api-key
            - name: OPENAI_API_KEY
              valueFrom:
                secretKeyRef:
                  name: mleval-secrets
                  key: openrouter-api-key
            - name: OPENROUTER_API_KEY
              valueFrom:
                secretKeyRef:
                  name: mleval-secrets
                  key: openrouter-api-key
            - name: HF_TOKEN
              valueFrom:
                secretKeyRef:
                  name: mleval-secrets
                  key: hf-token
                  optional: true

            - name: HF_HOME
              value: "/results/.hf-cache/hf"
            - name: TRANSFORMERS_CACHE
              value: "/results/.hf-cache/hf/transformers"
            - name: HF_DATASETS_CACHE
              value: "/results/.hf-cache/hf/datasets"
            - name: TORCH_HOME
              value: "/results/.hf-cache/torch"
            - name: PYTHONUNBUFFERED
              value: "1"
            - name: PYTORCH_CUDA_ALLOC_CONF
              value: "expandable_segments:True"

          volumeMounts:
            - name: cache-volume
              mountPath: /cache
            - name: results
              mountPath: /results
            - name: dev-shm
              mountPath: /dev/shm

      # Pin to a specific GPU product. Required because GPU_TYPE may be the
      # generic nvidia.com/gpu (e.g. for A10) — without this label selector
      # the scheduler would land us on any random card. See .env for the
      # full list of valid GPU_PRODUCT values.
      nodeSelector:
        nvidia.com/gpu.product: ${GPU_PRODUCT}

      tolerations:
        # Only tolerate taints we're authorized for. Do NOT add
        # `nautilus.io/reservation` (lets pods poach other groups' reserved
        # nodes) or `nautilus.io/hardware=large-gpu` (a hardware-class taint we
        # don't need for a 1-GPU job and aren't entitled to blanket-tolerate).
        # Per NRP policy you may only tolerate a reservation value if your group
        # is approved for it. Run on unreserved capacity only.
        - key: nvidia.com/gpu
          operator: Exists
          effect: PreferNoSchedule

      volumes:
        - name: cache-volume
          emptyDir:
            sizeLimit: 100Gi
        - name: results
          persistentVolumeClaim:
            claimName: mleval-results
        - name: dev-shm
          # Disk-backed (not medium: Memory) — memory-backed shm counts
          # against pod memory limit. MLEvolve subprocesses share /dev/shm
          # via torch DataLoader workers when num_workers>0.
          emptyDir:
            sizeLimit: 16Gi
