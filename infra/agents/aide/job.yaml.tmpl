# AIDE trajectory Job template. Rendered by `envsubst` per (task × cell × seed).
# DO NOT `kubectl apply -f` directly — apply via the orchestrator or
# `make k8s-apply-job-aide` which substitutes env vars from .env + flags.
#
# Required env at render time (top of orchestrator/run_ab.py wires these):
#   IMAGE_REGISTRY IMAGE_NAME IMAGE_TAG GPU_TYPE
#   MLEVAL_RUN_ID MLEVAL_TRAJECTORY_ID MLEVAL_LLM_MODEL
#   TASK CELL SEED TIME_LIMIT_SECONDS STEP_LIMIT
#   ACTIVE_DEADLINE_SECONDS                 (== TIME_LIMIT_SECONDS + slack)
#   MLEVAL_SKILL_PATH                       (empty for without_skill cell)

apiVersion: batch/v1
kind: Job
metadata:
  name: ${MLEVAL_TRAJECTORY_ID}
  labels:
    app: mleval
    agent: aide
    run_id: "${MLEVAL_RUN_ID}"
    task: "${TASK}"
    cell: "${CELL}"
    seed: "${SEED}"
spec:
  backoffLimit: 0
  activeDeadlineSeconds: ${ACTIVE_DEADLINE_SECONDS}
  ttlSecondsAfterFinished: 86400
  template:
    metadata:
      labels:
        app: mleval
        agent: aide
        run_id: "${MLEVAL_RUN_ID}"
        task: "${TASK}"
        cell: "${CELL}"
        seed: "${SEED}"
    spec:
      restartPolicy: Never
      # 90s grace gives the entrypoint SIGTERM-trap room to write manifest +
      # run analyzer chain (adapter -> classifier -> predicates).
      terminationGracePeriodSeconds: 90
      imagePullSecrets:
        - name: ghcr-pull
      containers:
        - name: agent
          image: ${IMAGE_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
          imagePullPolicy: Always
          # Per NRP policy: limit must be within 20% of request (and for jobs
          # at scale, limit == request). We use request == limit for full
          # compliance and to make the spec easy to reason about.
          # Right-sized for llama-inference: huggyllama/llama-7b fp16 load
          # peaks at ~13 GiB CPU RAM during from_pretrained; AIDE itself +
          # deps add ~2 GiB; 24 GiB leaves headroom for optimizations that
          # transiently double-load weights or import vllm/accelerate dispatch.
          # 2 CPU is enough — the GPU does the inference; CPU only matters
          # during one-shot tokenize (num_proc=4 burst) and pip install.
          # If a future task needs more (e.g., llama-13b), parameterize via
          # POD_CPU / POD_MEMORY envsubst vars threaded from the orchestrator.
          resources:
            requests:
              ${GPU_TYPE}: "1"
              cpu: "2"
              memory: "24Gi"
            limits:
              ${GPU_TYPE}: "1"
              cpu: "2"
              memory: "24Gi"
          env:
            - name: KUBE_NODE_NAME
              valueFrom:
                fieldRef:
                  fieldPath: spec.nodeName
            - name: MLEVAL_RUN_ID
              value: "${MLEVAL_RUN_ID}"
            - name: MLEVAL_TRAJECTORY_ID
              value: "${MLEVAL_TRAJECTORY_ID}"
            - name: TASK
              value: "${TASK}"
            - name: CELL
              value: "${CELL}"
            - name: SEED
              value: "${SEED}"
            - name: TIME_LIMIT_SECONDS
              value: "${TIME_LIMIT_SECONDS}"
            - name: STEP_LIMIT
              value: "${STEP_LIMIT}"
            - name: MLEVAL_LLM_MODEL
              value: "${MLEVAL_LLM_MODEL}"
            - name: MLEVAL_OUTPUT_DIR
              value: "/results/${MLEVAL_RUN_ID}/${MLEVAL_TRAJECTORY_ID}"
            - name: MLEVAL_TASK_INSTRUCTION_PATH
              value: "/results/data/${TASK}/instruction.md"
            - name: MLEVAL_TASK_DATA_DIR
              value: "/results/data/${TASK}/data"
            - name: MLEVAL_SKILL_PATH
              value: "${MLEVAL_SKILL_PATH}"
            - name: MLEVAL_TASK_REQS_PATH
              value: "${MLEVAL_TASK_REQS_PATH}"
            - name: MLEVAL_SKILL_REQS_PATH
              value: "${MLEVAL_SKILL_REQS_PATH}"
            - name: MLEVAL_LLM_TIMEOUT_SEC
              value: "${MLEVAL_LLM_TIMEOUT_SEC}"
            - name: GENERATE_REPORT
              value: "false"

            # Route AIDE's openai backend at OpenRouter (see entrypoint comment).
            - name: OPENAI_BASE_URL
              value: "https://openrouter.ai/api/v1"
            - name: MLEVAL_LLM_API_KEY
              valueFrom:
                secretKeyRef:
                  name: mleval-secrets
                  key: openrouter-api-key
            - name: OPENAI_API_KEY
              valueFrom:
                secretKeyRef:
                  name: mleval-secrets
                  key: openrouter-api-key
            - name: OPENROUTER_API_KEY
              valueFrom:
                secretKeyRef:
                  name: mleval-secrets
                  key: openrouter-api-key
            - name: HF_TOKEN
              valueFrom:
                secretKeyRef:
                  name: mleval-secrets
                  key: hf-token
                  optional: true

            # HF cache on PVC so model weights are downloaded once per sweep,
            # not once per trajectory. Use `make hf-warm MODEL=<name>` to pre-
            # populate it before launching A/B Jobs (avoids parallel-download
            # races between the first cohort of pods).
            - name: HF_HOME
              value: "/results/.hf-cache/hf"
            - name: TRANSFORMERS_CACHE
              value: "/results/.hf-cache/hf/transformers"
            - name: HF_DATASETS_CACHE
              value: "/results/.hf-cache/hf/datasets"
            - name: TORCH_HOME
              value: "/results/.hf-cache/torch"
            - name: PYTHONUNBUFFERED
              value: "1"
            - name: PYTORCH_CUDA_ALLOC_CONF
              value: "expandable_segments:True"

          volumeMounts:
            - name: cache-volume
              mountPath: /cache
            - name: results
              mountPath: /results
            - name: dev-shm
              mountPath: /dev/shm

      tolerations:
        - key: nautilus.io/reservation
          operator: Exists
          effect: NoSchedule
        - key: nautilus.io/hardware
          operator: Equal
          value: large-gpu
          effect: NoSchedule
        - key: nvidia.com/gpu
          operator: Exists
          effect: PreferNoSchedule

      volumes:
        - name: cache-volume
          emptyDir:
            sizeLimit: 100Gi
        - name: results
          persistentVolumeClaim:
            claimName: mleval-results
        - name: dev-shm
          emptyDir:
            medium: Memory
            sizeLimit: 8Gi
