# AIDE CPU-only trajectory Job template. Rendered by `envsubst` per (task × cell × seed).
#
# Use this template when the task does NOT need a GPU (e.g., tabular tasks
# like house-prices). NRP-policy compliance baked in:
#   - request == limit, ≤ 1 CPU and ≤ 2 GiB → exempt from utilization-floor enforcement
#   - priorityClassName: opportunistic           (preemptible; doesn't block GPU work)
#   - nodeAffinity: NotIn pci-10de.present       (don't squat on GPU nodes)
#   - no GPU resource request
#
# Apply via `python -m infra.orchestrator.run_ab --profile cpu ...`.

apiVersion: batch/v1
kind: Job
metadata:
  name: ${MLEVAL_TRAJECTORY_ID}
  labels:
    app: mleval
    agent: aide
    profile: cpu
    run_id: "${MLEVAL_RUN_ID}"
    task: "${TASK}"
    cell: "${CELL}"
    seed: "${SEED}"
spec:
  backoffLimit: 0
  activeDeadlineSeconds: ${ACTIVE_DEADLINE_SECONDS}
  ttlSecondsAfterFinished: 86400
  template:
    metadata:
      labels:
        app: mleval
        agent: aide
        profile: cpu
        run_id: "${MLEVAL_RUN_ID}"
        task: "${TASK}"
        cell: "${CELL}"
        seed: "${SEED}"
    spec:
      restartPolicy: Never
      priorityClassName: opportunistic
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - key: feature.node.kubernetes.io/pci-10de.present
                    operator: NotIn
                    values: ["true"]
      imagePullSecrets:
        - name: ghcr-pull
      containers:
        - name: agent
          image: ${IMAGE_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
          imagePullPolicy: Always
          resources:
            requests:
              cpu: "1"
              memory: "2Gi"
            limits:
              cpu: "1"
              memory: "2Gi"
          env:
            - name: KUBE_NODE_NAME
              valueFrom:
                fieldRef:
                  fieldPath: spec.nodeName
            - name: MLEVAL_RUN_ID
              value: "${MLEVAL_RUN_ID}"
            - name: MLEVAL_TRAJECTORY_ID
              value: "${MLEVAL_TRAJECTORY_ID}"
            - name: TASK
              value: "${TASK}"
            - name: CELL
              value: "${CELL}"
            - name: SEED
              value: "${SEED}"
            - name: TIME_LIMIT_SECONDS
              value: "${TIME_LIMIT_SECONDS}"
            - name: STEP_LIMIT
              value: "${STEP_LIMIT}"
            - name: MLEVAL_LLM_MODEL
              value: "${MLEVAL_LLM_MODEL}"
            - name: MLEVAL_OUTPUT_DIR
              value: "/results/${MLEVAL_RUN_ID}/${MLEVAL_TRAJECTORY_ID}"
            - name: MLEVAL_TASK_INSTRUCTION_PATH
              value: "/results/data/${TASK}/instruction.md"
            - name: MLEVAL_TASK_DATA_DIR
              value: "/results/data/${TASK}/data"
            - name: MLEVAL_SKILL_PATH
              value: "${MLEVAL_SKILL_PATH}"
            - name: GENERATE_REPORT
              value: "false"

            # Route AIDE's openai backend at OpenRouter (see entrypoint comment).
            - name: OPENAI_BASE_URL
              value: "https://openrouter.ai/api/v1"
            - name: MLEVAL_LLM_API_KEY
              valueFrom:
                secretKeyRef:
                  name: mleval-secrets
                  key: openrouter-api-key
            - name: OPENAI_API_KEY
              valueFrom:
                secretKeyRef:
                  name: mleval-secrets
                  key: openrouter-api-key
            - name: OPENROUTER_API_KEY
              valueFrom:
                secretKeyRef:
                  name: mleval-secrets
                  key: openrouter-api-key
            - name: HF_TOKEN
              valueFrom:
                secretKeyRef:
                  name: mleval-secrets
                  key: hf-token
                  optional: true

            - name: HF_HOME
              value: "/cache/hf"
            - name: TRANSFORMERS_CACHE
              value: "/cache/hf/transformers"
            - name: HF_DATASETS_CACHE
              value: "/cache/hf/datasets"
            - name: TORCH_HOME
              value: "/cache/torch"
            - name: PYTHONUNBUFFERED
              value: "1"

          volumeMounts:
            - name: cache-volume
              mountPath: /cache
            - name: results
              mountPath: /results
            - name: dev-shm
              mountPath: /dev/shm

      volumes:
        - name: cache-volume
          emptyDir:
            sizeLimit: 10Gi
        - name: results
          persistentVolumeClaim:
            claimName: mleval-results
        - name: dev-shm
          emptyDir:
            medium: Memory
            sizeLimit: 1Gi
