# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Local config — never commit real values. .env.example is the committed template.
.env
.env.*
!.env.example

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
logs/

# Model artifacts & data
*.pth
*.pt
*.ckpt
*.h5
*.pkl
*.npy
*.npz

# IDEs
.vscode/
.idea/
*.swp
*.swo
pulled-results/

# Skill builder outputs — Stage 1 grading artifacts belong in
# ~/.openclaw/skills/<name>/evals/, not in the staged eval repo.
# If a skill rebuild drops them in-tree, they're filtered here so they
# don't bloat the staging rsync to the PVC.
infra/skills/*/evals/

# LaTeX build byproducts (docs/project-overview/ compiles project-report.tex).
# The .tex source and the rendered .pdf are tracked; these intermediates are not.
docs/project-overview/*.aux
docs/project-overview/*.fls
docs/project-overview/*.fdb_latexmk
docs/project-overview/*.out
docs/project-overview/*.synctex.gz
docs/project-overview/*.log
docs/project-overview/*.toc

